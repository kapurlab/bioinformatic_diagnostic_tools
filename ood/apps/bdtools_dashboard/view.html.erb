<%- if host && port -%>
<div class="d-flex flex-column gap-3 py-2">
  <div class="d-flex gap-3 justify-content-center">
    <a href="/rnode/<%= host %>/<%= port %>/?t=<%= password %>" target="_blank" class="btn btn-success btn-lg px-4">
      &#x1F9EC; Open Diagnostic Tools
    </a>
  </div>
  <p class="text-center text-muted small mb-0">
    Every tool opens inside this one session, on the node it just allocated.
  </p>
</div>
<%- end -%>
