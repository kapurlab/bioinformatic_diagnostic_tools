#!/usr/bin/env bash
# bdtools — the Kapur Lab tool-suite manager.
#
# One entry point to install, run, and update the lab's bioinformatics GUIs
# across environments. Reads the suite manifest (tools.yml) and dispatches to
# the install-*.sh helpers.
#
#   bdtools list                       show the tools in the manifest
#   bdtools status                      show what is installed vs. the manifest
#   bdtools install <tool|all> [opts]   install a tool (default mode: --local)
#   bdtools local   <tool> [--port N]   run a locally-installed tool (standalone)
#   bdtools dashboard [--port N]         local landing page: pick + launch a GUI
#   bdtools check-updates [tool|all]    report newer upstream versions
#   bdtools update  <tool|all> [opts]   move a tool to its latest version
#   bdtools site-init [opts]            one-time bare-metal site bootstrap
#   bdtools test    <tool|all> [opts]   validate a deployment on a known sample
#
# Install modes (pass to `install`):
#   --local      standalone: conda env + uvicorn + browser (Linux/macOS/WSL2). DEFAULT.
#   --sandbox    per-user OOD sandbox app in ~/ondemand/dev   (institutional OOD)
#   --server     system OOD app install                       (sysadmin / bare-metal)
#
# By default --server installs ONLY the production card a normal user sees.
#   --with-dev   (server only) ALSO install the developer branch-picker card(s).
#                Developers only — keep off for routine diagnostic sites.
#
# Common options: --prefix DIR, --site-conf PATH (server/site-init), --dry-run, -h|--help
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

usage() { sed -n '2,27p' "$0" | sed 's/^# \{0,1\}//'; }

cmd_list() {
  printf '%-22s %-26s %s\n' "TOOL" "VERSION (pinned)" "OOD APP(S)"
  while read -r name; do
    [[ -n "$name" ]] || continue
    printf '%-22s %-26s %s\n' "$name" "$(manifest_get "$name" version)" "$(manifest_get "$name" ood_apps)"
  done < <(manifest_names)
  echo
  echo "suite_version: $(manifest_suite_version)   manifest: ${MANIFEST}"
}

cmd_status() {
  printf '%-22s %-18s %-18s %s\n' "TOOL" "PINNED" "INSTALLED" "CHECKOUT"
  while read -r name; do
    [[ -n "$name" ]] || continue
    local dir installed="(not installed)"
    dir="$(tool_dir "$name")"
    if [[ -d "${dir}/.git" ]]; then
      installed="$(git -C "$dir" describe --tags --always 2>/dev/null || echo '?')"
    fi
    printf '%-22s %-18s %-18s %s\n' "$name" "$(manifest_get "$name" version)" "$installed" "$dir"
  done < <(manifest_names)
}

cmd_install() {
  local mode="local"; local raw=() passthru=() with_dev=0 no_dashboard=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local)   mode="local";   shift;;
      --sandbox) mode="sandbox"; shift;;
      --server)  mode="server";  shift;;
      --dry-run)   DRY_RUN=1; export DRY_RUN; passthru+=(--dry-run); shift;;
      --prefix)    export BDTOOLS_HOME="$2"; passthru+=(--prefix "$2"); shift 2;;
      --site-conf) passthru+=(--site-conf "$2"); shift 2;;
      --with-dev)  with_dev=1; shift;;
      --no-dashboard) no_dashboard=1; shift;;   # local: don't auto-open the dashboard at the end
      -*)          die "install: unknown option '$1'";;
      *)         raw+=("$1"); shift;;
    esac
  done
  # --with-dev is a server-only opt-in (developer branch-picker cards).
  if [[ ${with_dev} -eq 1 ]]; then
    [[ "${mode}" == "server" ]] || die "--with-dev only applies to --server installs"
    passthru+=(--with-dev)
  fi
  [[ ${#raw[@]} -gt 0 ]] || die "install: name a tool or 'all' (see: bdtools list)"
  local targets=() r n
  for r in "${raw[@]}"; do
    if [[ "$r" == all ]]; then
      while read -r n; do [[ -n "$n" ]] && targets+=("$n"); done < <(manifest_names)
    else
      manifest_has "$r" || die "unknown tool: $r (see: bdtools list)"
      targets+=("$r")
    fi
  done
  local script="${KT_BIN_DIR}/install-${mode}.sh"
  [[ -x "$script" ]] || die "no installer for mode '${mode}' (${script})"
  # install = build only (never auto-launch); `bdtools local <tool>` launches.
  [[ "${mode}" == "local" ]] && passthru+=(--build-only)
  local rc=0 skipped=()
  for t in "${targets[@]}"; do
    if "$script" "$t" "${passthru[@]}"; then :; else
      local ec=$?
      if [[ ${ec} -eq 3 ]]; then skipped+=("$t");   # no local-build path (OOD-only) — not a failure
      else warn "install failed: ${t}"; rc=1; fi
    fi
  done
  if [[ ${#skipped[@]} -gt 0 ]]; then
    warn "skipped (no local install — OOD-only): ${skipped[*]}"
  fi

  # Local installs: tell the user their access point, then open the dashboard.
  if [[ "${mode}" == "local" && ${rc} -eq 0 && ${DRY_RUN:-0} -eq 0 ]]; then
    # Example tool = first target that actually installed locally (skip OOD-only).
    local first="" t2
    for t2 in "${targets[@]}"; do
      [[ " ${skipped[*]} " == *" ${t2} "* ]] || { first="${t2}"; break; }
    done
    [[ -n "${first}" ]] || first="mlst_gui"
    echo
    ok "Install complete."
    cat <<EOF

  Your tools are here:   ${REPO_DIR}

  Open the dashboard (pick any installed GUI):
      bin/bdtools dashboard
      # then open http://127.0.0.1:8080/

  …or launch a single tool directly:
      bin/bdtools local ${first} --port 8080
      # then open http://127.0.0.1:8080/

  Validate the deployment against known samples:
      bin/bdtools test all
EOF
    if [[ ${no_dashboard} -eq 0 && -t 1 ]]; then
      echo; info "opening the dashboard (Ctrl-C to stop; re-open later with 'bin/bdtools dashboard')…"
      cmd_dashboard
    fi
  fi
  return $rc
}

cmd_local() {
  [[ $# -ge 1 ]] || die "usage: bdtools local <tool> [--port N] [--no-browser]"
  manifest_has "$1" || die "unknown tool: $1"
  # build-if-needed, then launch (the build steps are idempotent). Forward the
  # rest of the args (--port, --no-browser, ...) to the launcher.
  "${KT_BIN_DIR}/install-local.sh" --run-only "$@"
}

cmd_dashboard() {
  # Local landing page: lists installed GUIs and launches the one you pick.
  exec python3 "${KT_BIN_DIR}/dashboard.py" "$@"
}

cmd_check_updates() { "${KT_BIN_DIR}/check-updates.sh" "${1:-all}"; }

cmd_update() {
  [[ $# -ge 1 ]] || die "usage: bdtools update <tool|all> [--dry-run]"
  "${KT_BIN_DIR}/check-updates.sh" --apply "$@"
}

cmd_site_init() { "${KT_BIN_DIR}/site-init.sh" "$@"; }

cmd_test() {
  [[ $# -ge 1 ]] || die "usage: bdtools test <tool|all> [--record] [--keep]"
  "${KT_BIN_DIR}/test.sh" "$@"
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 0; }
  local cmd="$1"; shift
  case "$cmd" in
    list)               cmd_list "$@";;
    status)             cmd_status "$@";;
    install)            cmd_install "$@";;
    local)              cmd_local "$@";;
    dashboard)          cmd_dashboard "$@";;
    check-updates)      cmd_check_updates "$@";;
    update)             cmd_update "$@";;
    site-init)          cmd_site_init "$@";;
    test)               cmd_test "$@";;
    -h|--help|help)     usage;;
    *) die "unknown command: ${cmd} (see: bdtools --help)";;
  esac
}
main "$@"
