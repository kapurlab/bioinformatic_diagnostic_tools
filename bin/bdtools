#!/usr/bin/env bash
# bdtools — the Kapur Lab tool-suite manager.
#
# One entry point to install, run, and update the lab's bioinformatics GUIs
# across environments. Reads the suite manifest (tools.yml) and dispatches to
# the install-*.sh helpers.
#
#   bdtools list                       show the tools in the manifest
#   bdtools status                      show what is installed vs. the manifest
#   bdtools install <tool|all> [opts]   install a tool (default mode: --local)
#   bdtools local   <tool> [--port N]   run a locally-installed tool (standalone)
#   bdtools dashboard [--port N]         local landing page: pick + launch a GUI
#                     [--restart|--stop] restart (after a pull) or stop it + tools
#   bdtools check-updates [tool|all]    report newer upstream versions
#   bdtools update  <tool|all> [opts]   move a tool to its latest version
#   bdtools site-init [opts]            one-time bare-metal site bootstrap
#   bdtools setup-databases [opts]      download shared reference DBs + wire the GUIs
#   bdtools doctor  [tool ...]          check installs are runnable; print fixes
#   bdtools lint    [tool ...]          (maintainer) flag dependency drift in repos
#   bdtools test    <tool|all> [opts]   validate a deployment on a known sample
#
# Install modes (pass to `install`):
#   --local      standalone: conda env + uvicorn + browser (Linux/macOS/WSL2). DEFAULT.
#   --sandbox    per-user OOD sandbox app in ~/ondemand/dev   (institutional OOD)
#   --server     system OOD app install                       (sysadmin / bare-metal)
#
# By default --server installs ONLY the production card a normal user sees.
#   --with-dev   (server only) ALSO install the developer branch-picker card(s).
#                Developers only — keep off for routine diagnostic sites.
#
# Common options: --prefix DIR, --site-conf PATH (server/site-init), --dry-run, -h|--help
set -euo pipefail

# Resolve this script's real path, following symlinks, so `bdtools` can be
# symlinked (into the repo root, onto $PATH, ~/bin, …) and still find its libs.
# Portable for bash 3.2 (macOS) — no `readlink -f`. Handles relative/absolute
# targets and symlink chains.
_bdt_src="${BASH_SOURCE[0]}"
while [[ -h "${_bdt_src}" ]]; do
  _bdt_dir="$(cd -P "$(dirname "${_bdt_src}")" && pwd)"
  _bdt_src="$(readlink "${_bdt_src}")"
  [[ "${_bdt_src}" != /* ]] && _bdt_src="${_bdt_dir}/${_bdt_src}"
done
_bdt_dir="$(cd -P "$(dirname "${_bdt_src}")" && pwd)"
source "${_bdt_dir}/lib/common.sh"

usage() { sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'; }

cmd_list() {
  printf '%-22s %-26s %s\n' "TOOL" "VERSION (pinned)" "OOD APP(S)"
  while read -r name; do
    [[ -n "$name" ]] || continue
    printf '%-22s %-26s %s\n' "$name" "$(manifest_get "$name" version)" "$(manifest_get "$name" ood_apps)"
  done < <(manifest_names)
  echo
  echo "suite_version: $(manifest_suite_version)   manifest: ${MANIFEST}"
}

cmd_status() {
  printf '%-22s %-18s %-18s %s\n' "TOOL" "PINNED" "INSTALLED" "CHECKOUT"
  while read -r name; do
    [[ -n "$name" ]] || continue
    local dir installed="(not installed)"
    dir="$(tool_dir "$name")"
    if [[ -d "${dir}/.git" ]]; then
      installed="$(git -C "$dir" describe --tags --always 2>/dev/null || echo '?')"
    fi
    printf '%-22s %-18s %-18s %s\n' "$name" "$(manifest_get "$name" version)" "$installed" "$dir"
  done < <(manifest_names)
}

cmd_install() {
  local mode="local"; local raw=() passthru=() with_dev=0 no_dashboard=0 dashboard=0 site_conf=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local)   mode="local";   shift;;
      --sandbox) mode="sandbox"; shift;;
      --server)  mode="server";  shift;;
      --dry-run)   DRY_RUN=1; export DRY_RUN; passthru+=(--dry-run); shift;;
      --prefix)    export BDTOOLS_HOME="$2"; passthru+=(--prefix "$2"); shift 2;;
      --site-conf) site_conf="$2"; passthru+=(--site-conf "$2"); shift 2;;
      --with-dev)  with_dev=1; shift;;
      --no-card)   passthru+=(--no-card); shift;;   # server: build a tool's env but skip its per-tool card
      --dashboard) dashboard=1; shift;;             # server: install the consolidated dashboard card
      --no-dashboard) no_dashboard=1; shift;;   # local: don't auto-open the dashboard at the end
      -*)          die "install: unknown option '$1'";;
      *)         raw+=("$1"); shift;;
    esac
  done
  # --dashboard installs the single umbrella-owned card (no tool positional).
  if [[ ${dashboard} -eq 1 ]]; then
    [[ "${mode}" == "server" ]] || die "--dashboard only applies to --server installs"
    local dargs=(); [[ ${DRY_RUN:-0} -eq 1 ]] && dargs+=(--dry-run)
    [[ -n "${site_conf}" ]] && dargs+=(--site-conf "${site_conf}")
    exec "${KT_BIN_DIR}/install-server.sh" --dashboard ${dargs[@]+"${dargs[@]}"}
  fi
  # --with-dev is a server-only opt-in (developer branch-picker cards).
  if [[ ${with_dev} -eq 1 ]]; then
    [[ "${mode}" == "server" ]] || die "--with-dev only applies to --server installs"
    passthru+=(--with-dev)
  fi
  [[ ${#raw[@]} -gt 0 ]] || die "install: name a tool or 'all' (see: bdtools list)"
  local targets=() r n
  for r in "${raw[@]}"; do
    if [[ "$r" == all ]]; then
      while read -r n; do [[ -n "$n" ]] && targets+=("$n"); done < <(manifest_names)
    else
      manifest_has "$r" || die "unknown tool: $r (see: bdtools list)"
      targets+=("$r")
    fi
  done
  local script="${KT_BIN_DIR}/install-${mode}.sh"
  [[ -x "$script" ]] || die "no installer for mode '${mode}' (${script})"
  # install = build only (never auto-launch); `bdtools local <tool>` launches.
  [[ "${mode}" == "local" ]] && passthru+=(--build-only)
  local rc=0 skipped=()
  for t in "${targets[@]}"; do
    if "$script" "$t" ${passthru[@]+"${passthru[@]}"}; then :; else
      local ec=$?
      if [[ ${ec} -eq 3 ]]; then skipped+=("$t");   # no local-build path (OOD-only) — not a failure
      else warn "install failed: ${t}"; rc=1; fi
    fi
  done
  if [[ ${#skipped[@]} -gt 0 ]]; then
    warn "skipped (no local install — OOD-only): ${skipped[*]}"
  fi

  # Local installs: tell the user their access point, then open the dashboard.
  if [[ "${mode}" == "local" && ${rc} -eq 0 && ${DRY_RUN:-0} -eq 0 ]]; then
    # Example tool = first target that actually installed locally (skip OOD-only).
    local first="" t2
    for t2 in "${targets[@]}"; do
      [[ " ${skipped[*]-} " == *" ${t2} "* ]] || { first="${t2}"; break; }
    done
    [[ -n "${first}" ]] || first="mlst_gui"
    echo
    ok "Install complete."
    cat <<EOF

  Your tools are here:   ${REPO_DIR}

  The dashboard opens in your browser now. Pick a tool and it opens in a tab.
  Keep the dashboard window open while you work.

  To open the dashboard again later (e.g. after restarting your computer):
      • macOS: double-click  "Open Dashboard.command"  in the folder above
      • or run:  bin/bdtools dashboard      (then open http://127.0.0.1:8080/)

  Launch a single tool instead:
      bin/bdtools local ${first} --port 8080      # then open http://127.0.0.1:8080/

  Validate against known samples (optional):
      bin/bdtools test all
EOF
    # Offer to set up the shared reference databases (Kraken2, BLAST, vSNP
    # references). They're large and third-party, so they're fetched on demand
    # rather than bundled. Only the tools that need them benefit, but the prompt
    # is cheap and the alternative (a tool failing for a missing DB) is worse.
    if [[ -t 0 && -t 1 ]]; then
      echo
      read -r -p "Set up reference databases now (Kraken2, BLAST, vSNP)? [y/N]: " want_db
      if [[ "${want_db}" =~ ^[Yy] ]]; then
        "${KT_BIN_DIR}/setup-databases.sh" || warn "database setup did not complete — re-run later with 'bin/bdtools setup-databases'"
      else
        info "Skipped. Set them up anytime with:  bin/bdtools setup-databases"
      fi
    else
      # Non-interactive (e.g. a Claude agent runs bdtools as a subprocess, so
      # stdin isn't a TTY and we can't prompt). Don't silently skip — make the
      # next step explicit so it's surfaced in the agent's output and acted on.
      echo
      warn "Reference databases (Kraken2, BLAST, vSNP) are NOT set up yet — some tools need them."
      info "  ACTION: run  bin/bdtools setup-databases   (asks Home vs Shared), or pass --home / --shared."
    fi
    # Readiness summary: confirm each install can actually run, with fixes for
    # anything missing (a dependency or an un-set-up database). Non-fatal.
    echo; info "checking your installs are ready to run…"
    local doctor_json; doctor_json="$("${KT_BIN_DIR}/doctor.sh" --json 2>/dev/null || true)"
    "${KT_BIN_DIR}/doctor.sh" || true     # human-readable summary
    # Offer to refresh any env with a fixable gap (a missing dependency the spec
    # now declares). Platform limitations (e.g. bracken on macOS) are reported as
    # notes, not issues, so they don't trigger a rebuild that can't help.
    local need_rebuild
    need_rebuild="$(printf '%s' "${doctor_json}" | "${PYBIN}" -c '
import sys, json
try: data = json.load(sys.stdin)
except Exception: data = []
print(" ".join(sorted({t["tool"] for t in data
      for i in t.get("issues", []) if "bdtools update" in i.get("fix", "")})))' 2>/dev/null || true)"
    if [[ -n "${need_rebuild}" ]]; then
      if [[ -t 0 && -t 1 ]]; then
        echo; read -r -p "Rebuild the environment for: ${need_rebuild}? [Y/n]: " ans
        if [[ ! "${ans}" =~ ^[Nn] ]]; then
          local rt
          for rt in ${need_rebuild}; do
            "${KT_BIN_DIR}/install-local.sh" --build-only --rebuild "${rt}" || warn "rebuild of ${rt} did not complete"
          done
          echo; info "re-checking…"; "${KT_BIN_DIR}/doctor.sh" || true
        fi
      else
        echo
        warn "These tools need their environment refreshed: ${need_rebuild}"
        info "  ACTION: run  bin/bdtools update <tool>  for each (refreshes the env from its spec)."
      fi
    fi
    if [[ ${no_dashboard} -eq 0 && -t 1 ]]; then
      echo; info "opening the dashboard (Ctrl-C to stop; re-open later with 'bin/bdtools dashboard')…"
      cmd_dashboard
    fi
  fi
  return $rc
}

cmd_local() {
  [[ $# -ge 1 ]] || die "usage: bdtools local <tool> [--port N] [--no-browser]"
  manifest_has "$1" || die "unknown tool: $1"
  # build-if-needed, then launch (the build steps are idempotent). Forward the
  # rest of the args (--port, --no-browser, ...) to the launcher.
  "${KT_BIN_DIR}/install-local.sh" --run-only "$@"
}

# Pick a python that can run the reverse-proxy dashboard (needs starlette+httpx+
# uvicorn — present in every tool's conda env). Prints its path, or nothing.
#
# The candidate list MUST agree with tool_launch.py:_conda_bases(): that helper
# probes CONDA_BASE/CONDA_EXE and ~/miniconda3, ~/mambaforge, ~/anaconda3, /opt/…
# — not just ~/miniforge3. If this selector searched fewer places than the
# launcher, a box whose only proxy-capable env lives in (say) a group
# /…/miniconda3/envs/<tool> would silently fall back to the legacy multi-port
# dashboard even though the launcher could happily run every tool from it.
_dashboard_proxy_python() {
  local cand b

  # Explicit override always wins (set BDTOOLS_DASHBOARD_PYTHON=/path/to/python).
  if [[ -n "${BDTOOLS_DASHBOARD_PYTHON:-}" && -x "${BDTOOLS_DASHBOARD_PYTHON}" ]] \
     && "${BDTOOLS_DASHBOARD_PYTHON}" -c 'import starlette, httpx, uvicorn' >/dev/null 2>&1; then
    echo "${BDTOOLS_DASHBOARD_PYTHON}"; return 0
  fi

  # Conda bases to probe, mirroring tool_launch.py:_conda_bases() (order = priority).
  local bases=()
  [[ -n "${CONDA_BASE:-}" ]] && bases+=("${CONDA_BASE}")
  [[ -n "${CONDA_EXE:-}"  ]] && bases+=("$(dirname "$(dirname "${CONDA_EXE}")")")
  local condabin; condabin="$(command -v conda 2>/dev/null || true)"
  [[ -n "${condabin}" ]] && bases+=("$(dirname "$(dirname "${condabin}")")")
  [[ -n "${CONDA_PREFIX:-}" ]] && bases+=("${CONDA_PREFIX}")  # the active env itself
  bases+=("${HOME}/miniforge3" "${HOME}/miniconda3" "${HOME}/mambaforge" \
          "${HOME}/anaconda3" /opt/miniforge3 /opt/miniconda3)

  # Tool checkouts first (own <dir>/env), then every conda base's envs + base python.
  for cand in \
      "${BDTOOLS_TOOLSDIR:-/srv/kapurlab/tools}"/*/env/bin/python \
      "${HOME}/.local/share/bdtools/checkouts"/*/env/bin/python; do
    [[ -x "${cand}" ]] || continue
    if "${cand}" -c 'import starlette, httpx, uvicorn' >/dev/null 2>&1; then
      echo "${cand}"; return 0
    fi
  done
  for b in "${bases[@]}"; do
    for cand in "${b}"/envs/*/bin/python "${b}"/bin/python; do
      [[ -x "${cand}" ]] || continue
      if "${cand}" -c 'import starlette, httpx, uvicorn' >/dev/null 2>&1; then
        echo "${cand}"; return 0
      fi
    done
  done
  return 1
}

# Should the local dashboard require a one-time session token? Personal machines
# (your own Mac / a WSL box) don't need one — loopback is yours alone. A shared
# multi-user server does: other accounts share 127.0.0.1. Override: set
# BDTOOLS_DASHBOARD_AUTH=1 (force on) or =0 (force off).
_dashboard_wants_token() {
  case "${BDTOOLS_DASHBOARD_AUTH:-}" in
    1|true|yes|on)  return 0;;
    0|false|no|off) return 1;;
  esac
  [[ "$(uname -s)" == "Darwin" ]] && return 1                      # macOS desktop
  [[ -n "${WSL_DISTRO_NAME:-}" ]] && return 1                      # WSL2
  grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null && return 1  # older WSL
  return 0                                                          # assume shared server
}

cmd_dashboard() {
  # Landing page that lists installed GUIs and launches the one you pick. It
  # prefers the single-port reverse-proxy dashboard (bin/ood_dashboard/app.py):
  # each tool runs on a private loopback port and is served under /t/<tool>/, so
  # only ONE port ever needs to be reachable. Over SSH, forward just that port.
  # Falls back to the legacy per-tool-port dashboard if the proxy deps are absent.
  #   --restart  stop the running dashboard + any tools, then start fresh
  #              (use this after a `git pull` so new code takes effect)
  #   --stop     stop the running dashboard + any tools, and exit
  #   --port N   dashboard port (default 8080)   --no-browser  don't auto-open
  local mode=serve rest=() port=8080 no_browser=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --restart)    mode=restart; shift;;
      --stop)       mode=stop; shift;;
      --no-browser) no_browser=1; rest+=("$1"); shift;;
      --port=*)     port="${1#--port=}"; rest+=("$1"); shift;;
      --port)       port="${2:-8080}"; rest+=("$1"); shift
                    if [[ $# -gt 0 ]]; then rest+=("$1"); shift; fi;;
      *)            rest+=("$1"); shift;;
    esac
  done

  if [[ "${mode}" != serve ]]; then
    pkill -f "uvicorn app:app"            2>/dev/null || true   # the proxy dashboard
    pkill -f "${KT_BIN_DIR}/dashboard.py" 2>/dev/null || true   # the legacy dashboard
    pkill -f "uvicorn app.main:app"       2>/dev/null || true   # any tool servers
    ok "stopped the dashboard and any running tools."
    [[ "${mode}" == stop ]] && return 0
  fi

  # Decide which server to run (single-port proxy preferred; legacy fallback),
  # then run it under a restart supervisor below.
  local rundir; local -a runcmd=()
  local pyproxy; pyproxy="$(_dashboard_proxy_python || true)"
  if [[ -n "${pyproxy}" ]]; then
    export BDTOOLS_LOCAL=1
    local want_token=0; _dashboard_wants_token && want_token=1
    local url="http://127.0.0.1:${port}/"
    if [[ ${want_token} -eq 1 ]]; then
      export BDTOOLS_SESSION_TOKEN="$("${pyproxy}" -c 'import secrets; print(secrets.token_urlsafe(24))')"
      url="http://127.0.0.1:${port}/?t=${BDTOOLS_SESSION_TOKEN}"
    fi
    local bar="================================================================"
    printf '\n%s\n  Kapur Lab Diagnostic Tools — dashboard starting (single-port proxy).\n\n  Open this in your web browser:\n      %s\n\n' "${bar}" "${url}"
    [[ ${want_token} -eq 1 ]] && printf '  This link carries a one-time session key — treat it like a password.\n  Other accounts on this server cannot open the dashboard without it.\n\n'
    printf '  Working over SSH? Forward just this one port from your machine:\n      ssh -L %s:127.0.0.1:%s <this-host>\n\n  Keep this window open while you work (Ctrl-C stops everything).\n%s\n\n' "${port}" "${port}" "${bar}"
    if [[ ${no_browser} -eq 0 ]]; then
      ( sleep 1.5
        for o in open xdg-open wslview; do
          command -v "$o" >/dev/null 2>&1 && { "$o" "${url}" >/dev/null 2>&1; break; }
        done ) &
    fi
    rundir="${KT_BIN_DIR}/ood_dashboard"
    runcmd=("${pyproxy}" -m uvicorn app:app --host 127.0.0.1 --port "${port}" --log-level warning)
  else
    # Fallback: proxy deps absent — legacy dashboard (each tool on its own port; over
    # SSH you'd forward each one). Install any tool to pull in starlette/httpx/uvicorn.
    warn "reverse-proxy deps (starlette/httpx/uvicorn) not found — using the legacy dashboard."
    warn "tools will open on their own ports. Install a tool to enable single-port mode."
    rundir="${KT_BIN_DIR}"
    runcmd=("${PYBIN}" "${KT_BIN_DIR}/dashboard.py" ${rest[@]+"${rest[@]}"})
  fi

  cd "${rundir}" || die "cannot cd to ${rundir}"
  # Restart supervisor. The dashboard exits 42 to REQUEST a relaunch — that's the
  # in-browser "Restart" button, so updated code takes effect without you having
  # to come back to this terminal. Any other exit (0 = the "Shut down" button or a
  # normal stop, 130 = Ctrl-C) ends the loop and returns you to the shell.
  local _stop=0; trap '_stop=1' INT TERM
  local rc=0
  while :; do
    "${runcmd[@]}"; rc=$?
    if [[ ${rc} -eq 42 && ${_stop} -eq 0 ]]; then
      printf '\n  ↻ Restarting the dashboard (requested from your browser)…\n\n'
      continue
    fi
    break
  done
  exit ${rc}
}

cmd_check_updates() { "${KT_BIN_DIR}/check-updates.sh" "${1:-all}"; }

cmd_update() {
  [[ $# -ge 1 ]] || die "usage: bdtools update <tool|all> [--dry-run]"
  "${KT_BIN_DIR}/check-updates.sh" --apply "$@"
}

cmd_site_init() { "${KT_BIN_DIR}/site-init.sh" "$@"; }

cmd_setup_databases() { "${KT_BIN_DIR}/setup-databases.sh" "$@"; }

cmd_doctor() { "${KT_BIN_DIR}/doctor.sh" "$@"; }

cmd_lint() { "${KT_BIN_DIR}/lint.sh" "$@"; }

cmd_test() {
  [[ $# -ge 1 ]] || die "usage: bdtools test <tool|all> [--record] [--keep]"
  "${KT_BIN_DIR}/test.sh" "$@"
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 0; }
  local cmd="$1"; shift
  case "$cmd" in
    list)               cmd_list "$@";;
    status)             cmd_status "$@";;
    install)            cmd_install "$@";;
    local)              cmd_local "$@";;
    dashboard)          cmd_dashboard "$@";;
    check-updates)      cmd_check_updates "$@";;
    update)             cmd_update "$@";;
    site-init)          cmd_site_init "$@";;
    setup-databases)    cmd_setup_databases "$@";;
    doctor)             cmd_doctor "$@";;
    lint)               cmd_lint "$@";;
    test)               cmd_test "$@";;
    -h|--help|help)     usage;;
    *) die "unknown command: ${cmd} (see: bdtools --help)";;
  esac
}
main "$@"
