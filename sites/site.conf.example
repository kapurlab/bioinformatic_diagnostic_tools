# site.conf — site-specific values for `bdtools install --server`.
#
# Copy this file and pass it with --site-conf, or place it at sites/site.conf.
# It is sourced as bash, so keep it valid shell: VAR=value, no spaces around '='.
# It is the ONE place site-specific values live; the installer rewrites the
# Kapur Lab literals (/srv/kapurlab, kapurlab-admins, wgs3, vxk1, ...) in each
# tool's OOD app files from these values at install time.
#
# Wgs3 (Kapur Lab) reference values are shown in comments to diff against.

# ---- Site identity (used to rewrite branding/path literals) ----------------
# Short lowercase slug; replaces the literal 'kapurlab'.
#   wgs3 reference: kapurlab     example new site: nivedi
SITE_NAME=yoursite
# Human-readable display name; replaces the literal 'WGS3' in titles.
SITE_DISPLAY="Your Site"
# Shared data/install root; replaces '/srv/kapurlab'.
SITE_ROOT=/srv/${SITE_NAME}

# ---- OOD cluster the app cards target --------------------------------------
# Must match an existing /etc/ood/config/clusters.d/<CLUSTER_NAME>.yml.
# Replaces the hardcoded 'wgs3' cluster in each tool's form.yml.
# On an institutional cluster, set this to the site's cluster id (ask the OOD
# admin). On a bare-metal lab server you create it (ood-core/ bootstrap).
CLUSTER_NAME=yoursite

# ---- Where tool source + conda envs are installed (system-wide) ------------
# Replaces '/srv/kapurlab/tools'. Each tool is checked out at TOOLS_ROOT/<tool>
# and its conda env built at TOOLS_ROOT/<tool>/env.
TOOLS_ROOT=${SITE_ROOT}/tools
# Conda/mamba base used to build envs. Point at an existing miniforge.
CONDA_BASE=${TOOLS_ROOT}/miniforge3

# ---- OOD system-apps directory (where cards are registered) ----------------
SYS_APPS_DIR=/var/www/ood/apps/sys

# ---- Groups / admin (used to rewrite group + user literals; optional) ------
ADMINS_GROUP=${SITE_NAME}-admins
MEMBERS_GROUP=${SITE_NAME}-members
# Replaces the literal 'vxk1' if any tool references it. Optional.
ADMIN_USER=

# ---- Optional --------------------------------------------------------------
# Reference-DB root the tools' configs point at (staged separately, per tool).
DATABASES_ROOT=${SITE_ROOT}/databases
# Replaces the wgs3 reference IP (100.68.171.59) if present. Optional.
SERVERNAME=

# ---- Bare-metal OOD-core bootstrap (only if standing up OOD from scratch) ---
# Not used by `install --server` (which assumes OOD core exists). Consumed by
# ood-core/bootstrap_ood_core.sh on a fresh lab server. See docs/INSTALL_BARE_METAL.md.
OOD_VERSION=3.1
